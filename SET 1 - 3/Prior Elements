import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int count = 1;

        int max = sc.nextInt();

        for(int i = 1; i < n; i++) {
            int num = sc.nextInt();

            if(num > max) {
                count++;
                max = num;
            }
        }

        System.out.println(count);
    }
}