import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        long n = sc.nextLong();
        long product = 1;

        while(n > 0) {
            product *= (n % 10);
            n /= 10;
        }

        System.out.println(product);
    }
}